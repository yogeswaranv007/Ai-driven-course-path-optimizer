{
  "info": {
    "name": "Phase-2 Review - Learning Path Optimizer API",
    "_postman_id": "8b34014f-a1a2-4de2-b487-7cf8dcb40d56",
    "description": "Covers auth, profile CRUD, and roadmap APIs for Phase-2 evaluation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "testEmail", "value": "phase2.user@example.com" },
    { "key": "testPassword", "value": "Test123!@#" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "roadmapId", "value": "" },
    { "key": "taskId", "value": "day-1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const randomPart = Math.floor(Math.random() * 1000000);",
                  "pm.collectionVariables.set('testEmail', `phase2.user.${randomPart}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Register returns user and tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('user');",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.expect(body).to.have.property('refreshToken');",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phase2 Tester\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Login returns user and tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user.email).to.eql(pm.collectionVariables.get('testEmail'));",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Refresh rotates tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Logout success message', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Logged out successfully');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Login (After Logout for next tests)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Relogin status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Relogin updates tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Profile CRUD",
      "item": [
        {
          "name": "Add Skill",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Add skill status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Skill is added', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Skill added successfully');",
                  "  pm.expect(body.skills.some(s => s.name === 'React')).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"React\",\n  \"level\": \"beginner\"\n}"
            },
            "url": "{{baseUrl}}/profile/skills"
          }
        },
        {
          "name": "Update Skills",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Update skills status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Skills updated successfully', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Skills updated successfully');",
                  "  const react = body.skills.find(s => s.name === 'React');",
                  "  pm.expect(react.level).to.eql('advanced');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skills\": [\n    {\n      \"name\": \"React\",\n      \"level\": \"advanced\"\n    },\n    {\n      \"name\": \"Node.js\",\n      \"level\": \"intermediate\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/profile/skills"
          }
        },
        {
          "name": "Delete Skill",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delete skill status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Skill removed successfully', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Skill removed successfully');",
                  "  pm.expect(body.skills.some(s => s.name === 'React')).to.eql(false);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/profile/skills/React"
          }
        }
      ]
    },
    {
      "name": "Roadmap APIs",
      "item": [
        {
          "name": "Generate Roadmap",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Generate roadmap status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Roadmap is created and id captured', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.roadmap).to.have.property('_id');",
                  "  pm.collectionVariables.set('roadmapId', body.roadmap._id);",
                  "  pm.collectionVariables.set('taskId', 'day-1');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"Backend Developer\",\n  \"dailyLearningMinutes\": 90,\n  \"skillSource\": \"custom\",\n  \"skills\": [\n    {\n      \"name\": \"Node.js\",\n      \"level\": \"beginner\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/roadmaps/generate"
          }
        },
        {
          "name": "Get Roadmap",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get roadmap status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Roadmap payload contains phases', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('roadmap');",
                  "  pm.expect(body.roadmap.phases).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/roadmaps/{{roadmapId}}"
          }
        },
        {
          "name": "Update Task Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Update task status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Task status update acknowledged', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Task updated successfully');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": "{{baseUrl}}/roadmaps/{{roadmapId}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Delete Roadmap",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delete roadmap status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Delete success message', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Roadmap deleted successfully');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/roadmaps/{{roadmapId}}"
          }
        }
      ]
    }
  ]
}
